# Sanctions + PEP screening (OpenSanctions /match/default)
# Sign up: https://www.opensanctions.org/account/
# Free tier: non-commercial use only
OPENSANCTIONS_API_KEY=os_your_key_here

# Adverse media news search (Tavily AI Search)
# Sign up: https://app.tavily.com/
# Free tier: 1,000 searches per month, no credit card
TAVILY_API_KEY=tvly-your_key_here

# (Optional) Anthropic API key for live LLM-narrated SAR drafts.
# If not set, the app generates deterministic template-based narratives.
# Sign up: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Note: GLEIF KYB lookups require no API key (public reference data).
